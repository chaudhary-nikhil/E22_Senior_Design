# Copy to dashboard/.env (gitignored). Never commit real keys.
# Google AI Studio: https://aistudio.google.com/apikey
# After editing .env, restart wifi_session_processor.py so Insights → Generate insights can read the key.
GEMINI_API_KEY=
# Optional — default is gemini-1.5-flash (server will retry fallbacks if a model 404s)
# GEMINI_MODEL=gemini-1.5-flash

# --- AI coaching (/api/coaching/insights) — production hardening ---
# Rate limit per logged-in user (sliding window, in-memory). Set MAX=0 to disable (not recommended).
# GEMINI_COACHING_RL_MAX=12
# GEMINI_COACHING_RL_WINDOW_SEC=900

# Server logging: off (default) | audit (user id + counts only) | debug (truncated prompt/response).
# Clients may send header X-GoldenForm-Coaching-NoLog: 1 to skip all logging for that request.
# Or set localStorage gf_coaching_privacy_nolog = "1" in the browser.
# GEMINI_COACHING_LOG=off
